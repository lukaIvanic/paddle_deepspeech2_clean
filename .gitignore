# Local environment and editor files
.venv/
venv/
__pycache__/
*.py[cod]
.DS_Store
.idea/
.vscode/

# Official PaddleSpeech checkout is kept local, not vendored into this repo.
PaddleSpeech/
results/**/code_snapshot/paddlespeech/

# Local run outputs
/exp/
/log/

# VEPRAD corpus data and generated PaddleSpeech data are kept out of Git.
data/*

# Public split documentation/metadata is safe to track. JSONL manifests and raw
# audio/text stay ignored because they contain transcript data.
!data/test/
data/test/*
!data/test/README.md
!data/test/*.meta.json

!data/cross_validation_splits/
data/cross_validation_splits/*
!data/cross_validation_splits/README.md
!data/cross_validation_splits/*/
data/cross_validation_splits/*/*
!data/cross_validation_splits/*/README.md
!data/cross_validation_splits/*/*.meta.json

# Model and checkpoint artifacts
*.pdparams
*.pdopt
*.pdmodel
*.ckpt
*.onnx
*.pt
*.pth
*.safetensors

# Run details that include transcript text or generated data stay local.
results/*.out
results/*.pid
results/**/details/decoded/
results/**/details/eval/
results/**/details/logs/
results/**/details/model/
results/**/details/analysis/utterance_metrics.tsv
results/**/details/analysis/top_30_errors.md
results/**/details/analysis/*.tsv
results/**/details/generated/
results/**/details/logs/eval_*.log
results/**/details/logs/eval_*.stdout.log
results/**/details/logs/test*.log
results/**/details/model/checkpoints/
results/**/details/model/decode/
results/**/details/model/export/
results/**/details/model/log/
results/**/details/model/test/
results/**/details/model/visual/

# Legacy result layouts, kept ignored in case an old run dump exists locally.
results/**/exp/**/checkpoints/*.rsl
results/**/utterance_metrics.tsv
results/**/top_30_errors.md
results/**/data/
